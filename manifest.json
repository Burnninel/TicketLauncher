{
	"name": "Bling - Criar Ticket",
	"version": "1.0.0",
	"manifest_version": 3,
	"description": "Cria tickets de suporte no Bling com um clique",
	"icons": {
		"16": "assets/icon-16.png",
		"48": "assets/icon-48.png",
		"128": "assets/icon-128.png"
	},
	"host_permissions": [
		"https://bling.callsys.com.br/*",
		"https://www.bling.com.br/*"
	],
	"background": {
		"service_worker": "dist/background.js"
	},
	"content_scripts": [
		{
			"matches": ["https://bling.callsys.com.br/omnichannel*"],
			"js": ["dist/content.js"],
			"css": ["src/presentation/styles.css"],
			"run_at": "document_idle"
		}
	]
}
